{
  "name": "github-readme-suno-cards",
  "version": "0.0.0",
  "private": true,
  "description": "Display your Suno AI-generated music as dynamic cards in your GitHub README.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "check": "biome check .",
    "format": "biome format --write .",
    "build": "pnpm --filter @suno-cards/web build"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "next": "15.1.11",
    "typescript": "5.6.3"
  }
}
